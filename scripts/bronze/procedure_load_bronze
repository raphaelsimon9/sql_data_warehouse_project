			TABLOCK
		);
		SET @end_time = GETDATE();
		PRINT	'>>> Load Time Is: ' + CAST (DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' second';
		PRINT '=============================================================================================';


