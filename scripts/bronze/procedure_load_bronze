		PRINT '';
		PRINT '-----------------------------------------------------';
		PRINT 'CRM Files Uploaded Successfully!';
		PRINT '-----------------------------------------------------';
		PRINT '=============================================================================================';


		PRINT '';
		PRINT '>>> Truncating Table: bronze.erp_cust_az12';
		PRINT '';

		SET @start_time = GETDATE();
